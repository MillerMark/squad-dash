<UserControl x:Class="SquadDash.RestartStatusPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFFF99"
             Padding="0"
             Height="Auto"
             VerticalAlignment="Top">
    <Grid Height="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Message Text -->
        <TextBlock Grid.Column="0"
                   Text="Restart requested, waiting for current turn to complete before shutting down"
                   Foreground="#000000"
                   FontSize="12"
                   FontFamily="Segoe UI, Arial, sans-serif"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="12,0,12,0" />

        <!-- Close Button (X) -->
        <Button Grid.Column="1"
                Content="✕"
                Width="32"
                Height="32"
                Background="#FFFF99"
                Foreground="#000000"
                BorderThickness="0"
                Padding="0"
                FontSize="14"
                FontWeight="Bold"
                Cursor="Hand"
                Click="CloseButton_Click"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Style="{StaticResource RestartStatusCloseButtonStyle}" />
    </Grid>
</UserControl>
