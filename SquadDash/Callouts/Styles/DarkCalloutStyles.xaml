<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:local="clr-namespace:SquadDash">
    <!-- Document styles -->
    <sys:Double x:Key="Heading1FontSize" >42</sys:Double>
    <sys:Double x:Key="Heading2FontSize" >30</sys:Double>
    <sys:Double x:Key="Heading3FontSize" >18</sys:Double>
    <sys:Double x:Key="Heading4FontSize" >18</sys:Double>
    <sys:Double x:Key="Heading5FontSize" >12</sys:Double>
    <sys:Double x:Key="Heading6FontSize" >10</sys:Double>
    <Thickness x:Key="ListMargin" Left="35" Top="0" Right="0" Bottom="0"></Thickness>
    
    <Style TargetType="{x:Type FlowDocument}" x:Key="{x:Static local:Styles.DocumentStyleKey}">
        <Setter Property="FontFamily" Value="Calibri" />
        <Setter Property="Foreground" Value="#FFF0F0FF" />
        <Setter Property="TextAlignment" Value="Left" />
    </Style>

    <Style TargetType="{x:Type List}" x:Key="{x:Static local:Styles.ListKey}">
        <Setter Property="Margin" Value="{DynamicResource ListMargin}" />
        <Setter Property="Padding" Value="0,0,0,0" />
    </Style>

    <Style TargetType="{x:Type ListItem}" x:Key="{x:Static local:Styles.ListItemKey}">
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="Padding" Value="0,0,0,0" />
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.ParagraphStyleKey}">
        <Setter Property="Margin" Value="5"/>
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.CodeBlockStyleKey}">
        <Setter Property="Background" Value="#80d3d3d3" />
        <Setter Property="FontFamily" Value="Consolas, Lucida Sans Typewriter, Courier New" />
        <Setter Property="Margin" Value="10"/>
    </Style>
    <Style TargetType="{x:Type Run}" x:Key="{x:Static local:Styles.CodeStyleKey}">
        <Setter Property="Background" Value="#80d3d3d3" />
        <Setter Property="FontFamily" Value="Consolas, Lucida Sans Typewriter, Courier New" />
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.Heading1StyleKey}">
        <Setter Property="FontSize" Value="{DynamicResource Heading1FontSize}" />
        <Setter Property="Foreground" Value="#FF8CD9FF" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0" />
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.Heading2StyleKey}">
        <Setter Property="FontSize" Value="{DynamicResource Heading2FontSize}" />
        <Setter Property="Foreground" Value="#FF8CD9FF" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0" />
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.Heading3StyleKey}">
        <Setter Property="FontSize" Value="{DynamicResource Heading3FontSize}" />
        <Setter Property="Foreground" Value="#FF8CD9FF" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.Heading4StyleKey}">
        <Setter Property="FontSize" Value="{DynamicResource Heading4FontSize}" />
        <Setter Property="Foreground" Value="#FF8CD9FF" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="TextDecorations" Value="Underline" />
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.Heading5StyleKey}">
        <Setter Property="FontSize" Value="{DynamicResource Heading5FontSize}" />
    </Style>
    <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static local:Styles.Heading6StyleKey}">
        <Setter Property="FontSize" Value="{DynamicResource Heading6FontSize}" />
    </Style>
    <Style TargetType="{x:Type Hyperlink}" x:Key="{x:Static local:Styles.HyperlinkStyleKey}">
        <!-- no changes -->
    </Style>
    <Style TargetType="{x:Type Image}" x:Key="{x:Static local:Styles.ImageStyleKey}">
        <Setter Property="MaxHeight" Value="{Binding RelativeSource={RelativeSource Self}, Path=Source.(BitmapSource.PixelHeight)}" />
        <Setter Property="MaxWidth" Value="{Binding RelativeSource={RelativeSource Self}, Path=Source.(BitmapSource.PixelWidth)}" />
    </Style>
    <Style TargetType="{x:Type Section}" x:Key="{x:Static local:Styles.QuoteBlockStyleKey}">
        <Setter Property="BorderBrush" Value="LightGray" />
        <Setter Property="BorderThickness" Value="4,0,0,0" />
        <Setter Property="Foreground" Value="Gray" />
        <Setter Property="Padding" Value="16,0,0,0" />
    </Style>
    <Style TargetType="{x:Type Table}" x:Key="{x:Static local:Styles.TableStyleKey}">
        <Setter Property="BorderBrush" Value="#10ffffff"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="CellSpacing" Value="1"/>
    </Style>
    <Style TargetType="{x:Type TableCell}" x:Key="{x:Static local:Styles.TableCellStyleKey}">
        <Setter Property="BorderBrush" Value="#10ffffff"/>
        <Setter Property="BorderThickness" Value="1,1,0,0"/>
    </Style>
    <Style TargetType="{x:Type TableRow}" x:Key="{x:Static local:Styles.TableHeaderStyleKey}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style TargetType="{x:Type CheckBox}" x:Key="{x:Static local:Styles.TaskListStyleKey}">
        <Setter Property="Margin" Value="0,0,0,-2" />
    </Style>
    <Style TargetType="{x:Type Line}" x:Key="{x:Static local:Styles.ThematicBreakStyleKey}">
        <Setter Property="Stretch" Value="Fill" />
        <Setter Property="Stroke" Value="White" />
    </Style>
    <Style TargetType="{x:Type Span}" x:Key="{x:Static local:Styles.SubscriptStyleKey}">
        <Setter Property="Typography.Variants" Value="Subscript" />
    </Style>
    <Style TargetType="{x:Type Span}" x:Key="{x:Static local:Styles.SuperscriptStyleKey}">
        <Setter Property="Typography.Variants" Value="Superscript" />
    </Style>
    <Style TargetType="{x:Type Span}" x:Key="{x:Static local:Styles.StrikeThroughStyleKey}">
        <Setter Property="TextBlock.TextDecorations" Value="Strikethrough" />
    </Style>
    <Style TargetType="{x:Type Span}" x:Key="{x:Static local:Styles.InsertedStyleKey}">
        <Setter Property="TextBlock.TextDecorations" Value="Underline" />
    </Style>
    <Style TargetType="{x:Type Span}" x:Key="{x:Static local:Styles.MarkedStyleKey}">
        <Setter Property="Background" Value="Yellow" />
    </Style>

    <!-- SimpleMarkdownViewer Template-->
    <Style TargetType="local:SimpleMarkdownViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:SimpleMarkdownViewer">
                    <FlowDocumentScrollViewer Document="{TemplateBinding Document}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>