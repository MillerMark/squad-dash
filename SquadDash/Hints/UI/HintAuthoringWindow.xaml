<Window x:Class="SquadDash.HintAuthoringWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:SquadDash"
        Title="Hint Authoring"
        Width="840"
        Height="600"
        MinWidth="600"
        MinHeight="450"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppSurface}"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="4"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Minimal SimpleMarkdownViewer control template for the live preview panel. -->
        <!-- The heading-size resources from LightCalloutStyles are optional; the viewer degrades gracefully without them. -->
        <Style TargetType="local:SimpleMarkdownViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="local:SimpleMarkdownViewer">
                        <FlowDocumentScrollViewer Document="{TemplateBinding Document}"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />           <!-- custom title bar -->
            <RowDefinition Height="*" MinHeight="150" />  <!-- editor + preview -->
            <RowDefinition Height="Auto" />          <!-- fields -->
            <RowDefinition Height="Auto" />          <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource ChromeSurface}"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="Hint Authoring"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="{DynamicResource FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource LabelText}" />
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource PanelCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="CloseButton_Click">✕</Button>
            </Grid>
        </Border>

        <!-- ── Editor + Preview ─────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: live preview -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top"
                           Text="Preview"
                           FontWeight="SemiBold"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}"
                           Margin="0,0,0,4" />
                <Border Background="{DynamicResource CardSurface}"
                        BorderBrush="{DynamicResource InputBorder}"
                        BorderThickness="1"
                        Padding="8">
                    <local:SimpleMarkdownViewer x:Name="MarkdownPreview"
                                                Foreground="{DynamicResource BodyText}" />
                </Border>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource InputBorder}"
                          Cursor="SizeWE" />

            <!-- Right: markdown source editor -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top"
                           Text="Markdown Source"
                           FontWeight="SemiBold"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}"
                           Margin="0,0,0,4" />
                <local:MarkdownEditorToolbar x:Name="SourceToolbar"
                                             DockPanel.Dock="Top"
                                             ShowImageButton="False"
                                             ShowHrButton="False"
                                             Margin="0,0,0,4"
                                             TargetTextBox="{Binding ElementName=MarkdownEditor}" />
                <TextBox x:Name="MarkdownEditor"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         TextWrapping="Wrap"
                         Background="{DynamicResource InputSurface}"
                         Foreground="{DynamicResource LabelText}"
                         BorderBrush="{DynamicResource InputBorder}"
                         BorderThickness="1"
                         Padding="6"
                         FontFamily="Consolas"
                         FontSize="{DynamicResource FontSizeBody}"
                         TextChanged="MarkdownEditor_TextChanged" />
            </DockPanel>
        </Grid>

        <!-- ── Fields ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="8,0,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row A: Target (full width, readonly) -->
            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Left"
                           Text="Target:"
                           Width="90"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}" />
                <TextBox x:Name="TargetBox"
                         IsReadOnly="True"
                         Background="{DynamicResource InputSurface}"
                         Foreground="{DynamicResource BodyText}"
                         BorderBrush="{DynamicResource InputBorder}"
                         BorderThickness="1"
                         Padding="4,3" />
            </DockPanel>

            <!-- Row B: label-left / value-right stacked rows -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Priority -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Priority:"
                           VerticalAlignment="Center" Margin="0,0,6,6"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}" />
                <TextBox x:Name="PriorityBox" Grid.Row="0" Grid.Column="1"
                         Text="100" Margin="0,0,0,6"
                         Background="{DynamicResource InputSurface}"
                         Foreground="{DynamicResource LabelText}"
                         BorderBrush="{DynamicResource InputBorder}"
                         BorderThickness="1" Padding="4,3" />

                <!-- Max Show Count -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Show Count:"
                           VerticalAlignment="Center" Margin="0,0,6,6"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}" />
                <TextBox x:Name="MaxShowCountBox" Grid.Row="1" Grid.Column="1"
                         Text="3" Margin="0,0,0,6"
                         Background="{DynamicResource InputSurface}"
                         Foreground="{DynamicResource LabelText}"
                         BorderBrush="{DynamicResource InputBorder}"
                         BorderThickness="1" Padding="4,3" />

                <!-- Trigger -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Trigger:"
                           VerticalAlignment="Center" Margin="0,0,6,6"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}" />
                <ComboBox x:Name="TriggerComboBox" Grid.Row="2" Grid.Column="1"
                          Margin="0,0,0,6"
                          SelectionChanged="TriggerComboBox_SelectionChanged">
                    <ComboBoxItem Content="Idle" Tag="Idle" IsSelected="True" />
                    <ComboBoxItem Content="Action" Tag="Action" />
                </ComboBox>

                <!-- Trigger Notes (free-form voice/text) -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Trigger Notes:"
                           VerticalAlignment="Top" Margin="0,2,6,6"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}" />
                <TextBox x:Name="TriggerNotesBox" Grid.Row="3" Grid.Column="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="48"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,6"
                         Background="{DynamicResource InputSurface}"
                         Foreground="{DynamicResource LabelText}"
                         BorderBrush="{DynamicResource InputBorder}"
                         BorderThickness="1" Padding="4,3" />

                <!-- Action ID (conditional) -->
                <TextBlock Grid.Row="4" Grid.Column="0" x:Name="ActionIdLabel"
                           Text="Action ID:" VerticalAlignment="Center"
                           Margin="0,0,6,6"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}"
                           Visibility="Collapsed" />
                <TextBox x:Name="ActionIdBox" Grid.Row="4" Grid.Column="1"
                         Visibility="Collapsed"
                         Margin="0,0,0,6"
                         Background="{DynamicResource InputSurface}"
                         Foreground="{DynamicResource LabelText}"
                         BorderBrush="{DynamicResource InputBorder}"
                         BorderThickness="1" Padding="4,3" />

                <!-- Condition -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Condition:"
                           VerticalAlignment="Center" Margin="0,0,6,0"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource LabelText}" />
                <ComboBox x:Name="ConditionComboBox" Grid.Row="5" Grid.Column="1">
                    <ComboBoxItem Content="Always" Tag="always" IsSelected="True" />
                </ComboBox>
            </Grid>
        </Grid>

        <!-- ── Buttons ───────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{DynamicResource PanelSurface}"
                BorderBrush="{DynamicResource InputBorder}"
                BorderThickness="0,1,0,0"
                Padding="8">
            <Grid>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource BodyText}" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="TestButton"
                            Content="Test"
                            Style="{StaticResource ThemedButtonStyle}"
                            Margin="0,0,8,0"
                            Click="TestButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Style="{StaticResource ThemedButtonStyle}"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click" />
                    <Button x:Name="SaveButton"
                            Content="Save"
                            Style="{StaticResource ThemedButtonStyle}"
                            Click="SaveButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
